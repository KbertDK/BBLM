generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum CoachRole {
  ADMIN
  COMMISH
  COACH
}

enum LeagueStatus {
  READY
  ACTIVE
  ENDED
}

enum GameType {
  BLOOD_BOWL
  DUNGEON_BOWL
  BB7
}

enum RuleSetStatus {
  ACTIVE
  INACTIVE
}

model RuleSet {
  id              String        @id @default(cuid())
  name            String
  startIncome     Int
  numberOfPlayers Int           @default(16)
  gameType        GameType
  status          RuleSetStatus @default(ACTIVE)
  leagues         League[]
  createdAt       DateTime      @default(now())
}

model League {
  id          String       @id @default(cuid())
  name        String
  season      Int
  isHidden    Boolean      @default(false)
  status      LeagueStatus @default(READY)
  ruleSetId   String?
  ruleSet     RuleSet?     @relation(fields: [ruleSetId], references: [id], onDelete: SetNull)
  createdAt   DateTime     @default(now())
  teams       Team[]
  matches     Match[]
  divisions   Division[]
}

model Division {
  id        String   @id @default(cuid())
  name      String
  leagueId  String
  league    League   @relation(fields: [leagueId], references: [id])
  isHidden  Boolean  @default(false)
  createdAt DateTime @default(now())
  teams     Team[]
}

model Coach {
  id           String     @id @default(cuid())
  name         String
  alias        String?    @unique
  email        String     @unique
  phone        String?
  address      String?
  zip          String?
  city         String?
  passwordHash String?
  role         CoachRole  @default(COACH)
  isActive     Boolean    @default(true)
  teams        Team[]
  newsPosts    NewsPost[]
  createdAt    DateTime   @default(now())
}

model Race {
  id            String       @id @default(cuid())
  name          String       @unique
  rosterSource  String
  rerollPrice   Int
  hasApothecary Boolean
  teams         Team[]
  playerTypes   PlayerType[]
}

model PlayerType {
  id              String  @id @default(cuid())
  raceId          String
  race            Race    @relation(fields: [raceId], references: [id])
  name            String
  cost            Int
  maxCount        Int
  ma              Int
  st              Int
  ag              Int
  av              Int
  skillRollDouble String
  skillRollNormal String
  startingSkills  Skill[]
  teamPlayers     TeamPlayer[]
}

enum SkillCategory {
  G
  A
  P
  S
  M
  E
}

model Skill {
  id          String        @id @default(cuid())
  skillId     Int           @unique
  name        String        @unique
  category    SkillCategory
  skillRule   String
  playerTypes PlayerType[]
}

model Team {
  id          String    @id @default(cuid())
  name        String
  raceId      String
  coachId     String
  leagueId    String
  divisionId  String?
  race        Race      @relation(fields: [raceId], references: [id])
  coach       Coach     @relation(fields: [coachId], references: [id])
  league      League    @relation(fields: [leagueId], references: [id])
  division    Division? @relation(fields: [divisionId], references: [id], onDelete: SetNull)
  homeMatches Match[]   @relation("HomeTeam")
  awayMatches Match[]   @relation("AwayTeam")
  wins        Int          @default(0)
  losses      Int          @default(0)
  draws       Int          @default(0)
  players     TeamPlayer[]
  createdAt   DateTime     @default(now())
}

enum PlayerStatus {
  ACTIVE
  MNG
  DEAD
}

model TeamPlayer {
  id             String       @id @default(cuid())
  teamId         String
  team           Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
  playerTypeId   String
  playerType     PlayerType   @relation(fields: [playerTypeId], references: [id])
  number         Int
  name           String?
  status         PlayerStatus @default(ACTIVE)
  completePasses Int          @default(0)
  touchdowns     Int          @default(0)
  interceptions  Int          @default(0)
  casualties     Int          @default(0)
  createdAt      DateTime     @default(now())
}

model Match {
  id          String      @id @default(cuid())
  leagueId    String
  league      League      @relation(fields: [leagueId], references: [id])
  homeTeamId  String
  awayTeamId  String
  homeTeam    Team        @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam    Team        @relation("AwayTeam", fields: [awayTeamId], references: [id])
  scheduledAt DateTime
  status      MatchStatus @default(SCHEDULED)
  round       Int
  homeScore   Int?
  awayScore   Int?
  createdAt   DateTime    @default(now())
}

enum MatchStatus {
  SCHEDULED
  LIVE
  COMPLETED
}

model NewsPost {
  id        String   @id @default(cuid())
  title     String
  body      String
  authorId  String
  author    Coach    @relation(fields: [authorId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
