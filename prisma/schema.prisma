generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model RuleSet {
  id              String        @id @default(cuid())
  name            String
  startIncome     Int
  gameType        GameType
  status          RuleSetStatus @default(ACTIVE)
  createdAt       DateTime      @default(now())
  numberOfPlayers Int           @default(16)
  pointsDraw      Int           @default(1)
  pointsLoss      Int           @default(0)
  pointsWin       Int           @default(3)
  leagues         League[]
}

model League {
  id             String       @id @default(cuid())
  name           String
  season         Int
  isHidden       Boolean      @default(false)
  createdAt      DateTime     @default(now())
  status         LeagueStatus @default(READY)
  ruleSetId      String?
  divisions      Division[]
  ruleSet        RuleSet?     @relation(fields: [ruleSetId], references: [id])
  matches        Match[]
  teams          Team[]
  primaryCoaches Coach[]      @relation("CoachPrimaryLeague")
}

model Division {
  id          String       @id @default(cuid())
  name        String
  leagueId    String
  isHidden    Boolean      @default(false)
  createdAt   DateTime     @default(now())
  league      League       @relation(fields: [leagueId], references: [id])
  teams       Team[]
  tournaments Tournament[] @relation("DivisionToTournament")
}

model Tournament {
  id            String     @id @default(cuid())
  name          String
  crossDivision Boolean    @default(false)
  createdAt     DateTime   @default(now())
  divisions     Division[] @relation("DivisionToTournament")
  matches       Match[]
}

model Coach {
  id              String     @id @default(cuid())
  name            String
  email           String     @unique
  passwordHash    String?
  role            CoachRole  @default(COACH)
  createdAt       DateTime   @default(now())
  isActive        Boolean    @default(true)
  address         String?
  alias           String?    @unique
  city            String?
  phone           String?
  zip             String?
  primaryLeagueId String?
  newsPosts       NewsPost[]
  teams           Team[]
  primaryLeague   League?    @relation("CoachPrimaryLeague", fields: [primaryLeagueId], references: [id], onDelete: SetNull)
}

model Race {
  id              String         @id @default(cuid())
  name            String         @unique
  rosterSource    String
  rerollPrice     Int
  hasApothecary   Boolean
  tier            String         @default("1")
  tierDescription String?
  playerTypes     PlayerType[]
  teams           Team[]
  mdStarPlayers   MdStarPlayer[] @relation("StarPlayerToRace")
}

model PlayerType {
  id              String       @id @default(cuid())
  raceId          String
  name            String
  cost            Int
  maxCount        Int
  isJourneyman    Boolean      @default(false)
  ma              Int
  st              Int
  ag              Int
  av              Int
  skillRollDouble String
  skillRollNormal String
  race            Race         @relation(fields: [raceId], references: [id])
  teamPlayers     TeamPlayer[]
  startingSkills  Skill[]      @relation("PlayerTypeToSkill")
  matchMercs      MatchMerc[]
}

model Skill {
  id            String         @id @default(cuid())
  skillId       Int            @unique
  name          String         @unique
  category      SkillCategory
  skillRule     String
  playerTypes   PlayerType[]   @relation("PlayerTypeToSkill")
  mdStarPlayers MdStarPlayer[] @relation("StarPlayerToSkill")
}

model Team {
  id               String       @id @default(cuid())
  name             String
  raceId           String
  coachId          String
  leagueId         String
  divisionId       String?
  wins             Int          @default(0)
  losses           Int          @default(0)
  draws            Int          @default(0)
  createdAt        DateTime     @default(now())
  apothecary       Boolean      @default(false)
  assistantCoaches Int          @default(0)
  cheerleaders     Int          @default(0)
  fanFactor        Int          @default(0)
  rerolls          Int          @default(0)
  treasury         Int          @default(0)
  isActive         Boolean      @default(true)
  awayMatches      Match[]      @relation("AwayTeam")
  homeMatches      Match[]      @relation("HomeTeam")
  coach            Coach        @relation(fields: [coachId], references: [id])
  division         Division?    @relation(fields: [divisionId], references: [id])
  league           League       @relation(fields: [leagueId], references: [id])
  race             Race         @relation(fields: [raceId], references: [id])
  players          TeamPlayer[]
}

model TeamPlayer {
  id              String       @id @default(cuid())
  teamId          String
  playerTypeId    String
  number          Int
  createdAt       DateTime     @default(now())
  casualties      Int          @default(0)
  completePasses  Int          @default(0)
  interceptions   Int          @default(0)
  name            String?
  status          PlayerStatus @default(ACTIVE)
  touchdowns      Int          @default(0)
  mvp             Int          @default(0)
  niggling        String       @default("")
  ssp             Int          @default(0)
  value           Int          @default(0)
  teamGamesAtSack Int?
  playerType      PlayerType   @relation(fields: [playerTypeId], references: [id])
  team            Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)
}

model Match {
  id           String      @id @default(cuid())
  leagueId     String
  homeTeamId   String
  awayTeamId   String
  scheduledAt  DateTime?
  status       MatchStatus @default(SCHEDULED)
  round        Int
  homeScore    Int?
  awayScore    Int?
  createdAt    DateTime    @default(now())
  tournamentId      String?
  homeTeamValue     Int?
  awayTeamValue     Int?
  homeTeamFanFactor Int?
  awayTeamFanFactor Int?
  awayTeam          Team             @relation("AwayTeam", fields: [awayTeamId], references: [id])
  homeTeam          Team             @relation("HomeTeam", fields: [homeTeamId], references: [id])
  league            League           @relation(fields: [leagueId], references: [id])
  tournament        Tournament?      @relation(fields: [tournamentId], references: [id])
  events            MatchEvent[]
  mercs             MatchMerc[]
  starPlayers       MatchStarPlayer[]
}

model MatchStarPlayer {
  id           String       @id @default(cuid())
  matchId      String
  side         String
  starPlayerId String
  price        Int
  isCompanion  Boolean      @default(false)
  createdAt    DateTime     @default(now())
  match        Match        @relation(fields: [matchId], references: [id], onDelete: Cascade)
  starPlayer   MdStarPlayer @relation(fields: [starPlayerId], references: [id])
}

model MatchMerc {
  id           String     @id @default(cuid())
  matchId      String
  side         String
  playerTypeId String
  cost         Int
  createdAt    DateTime   @default(now())
  match        Match      @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerType   PlayerType @relation(fields: [playerTypeId], references: [id])
}

model MatchEvent {
  id             String        @id @default(cuid())
  matchId        String
  type           String
  label          String
  createdAt      DateTime      @default(now())
  scoringTeam    String?
  mdMatchEventId String?
  match          Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)
  mdMatchEvent   MdMatchEvent? @relation(fields: [mdMatchEventId], references: [id])
}

model MdMatchEvent {
  id             String       @id @default(cuid())
  name           String
  causesCasualty Boolean      @default(false)
  description    String?
  dieRoll        Int?
  eventType      String
  ssp            Int?
  createdAt      DateTime     @default(now())
  matchEvents    MatchEvent[]
}

model MdStarPlayer {
  id             String         @id @default(cuid())
  name           String         @unique
  price          Int?
  includedWithId String?
  ma             Int
  st             Int
  ag             Int
  av             Int
  notes           String?
  createdAt       DateTime          @default(now())
  includedWith    MdStarPlayer?     @relation("StarPlayerCompanion", fields: [includedWithId], references: [id])
  companions      MdStarPlayer[]    @relation("StarPlayerCompanion")
  skills          Skill[]           @relation("StarPlayerToSkill")
  races           Race[]            @relation("StarPlayerToRace")
  matchStarPlayers MatchStarPlayer[]
}

model NewsPost {
  id        String   @id @default(cuid())
  title     String
  body      String
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  coachNote String   @default("")
  playerId  String?
  teamId    String?
  author    Coach    @relation(fields: [authorId], references: [id])
}

enum CoachRole {
  ADMIN
  COMMISH
  COACH
}

enum LeagueStatus {
  READY
  ACTIVE
  ENDED
}

enum GameType {
  BLOOD_BOWL
  DUNGEON_BOWL
  BB7
}

enum RuleSetStatus {
  ACTIVE
  INACTIVE
}

enum SkillCategory {
  G
  A
  P
  S
  M
  E
}

enum PlayerStatus {
  ACTIVE
  MNG
  DEAD
  SACKED
}

enum MatchStatus {
  SCHEDULED
  LIVE
  COMPLETED
}
